<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>لوحة التحكم</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Kufi+Arabic:wght@300;400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-slate-100 min-h-screen">

  <header class="bg-white border-b border-slate-200">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
      <div>
        <h1 class="text-xl font-bold text-slate-800">لوحة التحكم</h1>
        <p class="text-sm text-slate-500">إدارة الشهادات</p>
      </div>

      <form action="/logout" method="POST">
        <button class="rounded-lg bg-red-600 text-white px-4 py-2 hover:bg-red-700 transition">
          تسجيل الخروج
        </button>
      </form>
    </div>
  </header>

  <main class="max-w-7xl mx-auto px-6 py-8">
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-lg font-semibold text-slate-800">الشهادات</h2>
        <a href="/certificates/new" class="rounded-lg bg-green-700 text-white px-4 py-2 hover:bg-green-800 transition">
          إضافة شهادة جديدة
        </a>
      </div>

      <% if (!certificates || certificates.length === 0) { %>
        <div class="rounded-xl border border-dashed border-slate-300 p-10 text-center text-slate-500">
          لا توجد شهادات حتى الآن
        </div>
      <% } else { %>
        <div class="overflow-x-auto">
          <table class="w-full text-sm text-right">
            <thead>
              <tr class="border-b border-slate-200 text-slate-600">
                <th class="py-3 px-3">الاسم</th>
                <th class="py-3 px-3">رقم الشهادة</th>
                <th class="py-3 px-3">الهوية</th>
                <th class="py-3 px-3">المنطقة</th>
                <th class="py-3 px-3">الإجراءات</th>
              </tr>
            </thead>
            <tbody>
              <% certificates.forEach((certificate) => { %>
                <tr class="border-b border-slate-100">
                  <td class="py-4 px-3"><%= certificate.fullName %></td>
                  <td class="py-4 px-3"><%= certificate.certificateNumber %></td>
                  <td class="py-4 px-3"><%= certificate.nationalId %></td>
                  <td class="py-4 px-3"><%= certificate.region %></td>
                  <td class="py-4 px-3">
                    <div class="flex flex-wrap gap-2">
                      <a href="/certificates/<%= certificate._id %>" class="px-3 py-2 rounded-lg bg-slate-100 text-slate-700">
                        عرض
                      </a>

                      <a href="/certificates/<%= certificate._id %>/edit" class="px-3 py-2 rounded-lg bg-amber-100 text-amber-700">
                        تعديل
                      </a>

                      <form action="/certificates/<%= certificate._id %>/delete" method="POST" onsubmit="return confirm('هل أنت متأكد من حذف هذه الشهادة؟');">
                        <button type="submit" class="px-3 py-2 rounded-lg bg-red-100 text-red-700">
                          حذف
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </main>

</body>
</html>